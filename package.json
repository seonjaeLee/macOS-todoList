{
  "name": "desktop-todo",
  "version": "1.0.0",
  "description": "macOS desktop post-it todo widget",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dir && rm -rf \"/Applications/todoList-myfunfun.app\" && cp -R \"dist/mac-arm64/todoList-myfunfun.app\" /Applications/"
  },
  "build": {
    "appId": "com.desktop-todo",
    "productName": "todoList-myfunfun",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "identity": null
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "widget.html",
      "widget.css",
      "widget.js",
      "memo-list.html",
      "memo-list.css",
      "memo-list.js",
      "guide.html",
      "Delete_icon.png",
      "status_icon.png"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8"
  }
}
